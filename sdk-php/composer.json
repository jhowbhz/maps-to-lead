{
    "name": "jhowbhz/maps-to-lead",
    "description": "SDK cliente (PHP) para a API Maps to Lead — prospecção de leads a partir do Google Maps. De maneira nenhuma apoiamos ou incentivamos a prática de SPAM.",
    "type": "library",
    "keywords": [
        "google-maps",
        "leads",
        "lead-generation",
        "prospeccao",
        "scraping",
        "webhook",
        "sdk",
        "api-client",
        "maps-to-lead"
    ],
    "homepage": "https://github.com/jhowbhz/maps-to-lead",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Henrique"
        }
    ],
    "support": {
        "issues": "https://github.com/jhowbhz/maps-to-lead/issues",
        "source": "https://github.com/jhowbhz/maps-to-lead"
    },
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Jhowbhz\\MapsToLead\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jhowbhz\\MapsToLead\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
