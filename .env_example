# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
NODE_ENV=development
HOST=127.0.0.1
PORT=9000

# Nível de log (pino): trace|debug|info|warn|error. Padrão: debug (dev)/info (prod).
# LOG_LEVEL=info

# ---------------------------------------------------------------------------
# 🔐 Painel /manager
# ---------------------------------------------------------------------------
# Token de acesso ao painel. Vazio = painel desabilitado (responde 503).
# Gere um forte, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MANAGER_TOKEN=troque-por-um-token-forte

# ---------------------------------------------------------------------------
# 🚦 Rate limiting (proteção contra flood/DoS)
# ---------------------------------------------------------------------------
# Máximo de requisições por IP dentro da janela. O painel (SSE + polling) usa
# bem pouco; suba se tiver muitos clientes atrás de um mesmo proxy/IP.
# RATE_LIMIT_WINDOW_MS=60000  # tamanho da janela (ms). Padrão 60s.
# RATE_LIMIT_MAX=600          # requisições por IP por janela. Padrão 600.

# ---------------------------------------------------------------------------
# 🗄️ Persistência (SQLite)
# ---------------------------------------------------------------------------
# Caminho do banco (jobs + leads sobrevivem a reinícios). Padrão: ./data/leads.db
# DB_PATH=./data/leads.db

# ---------------------------------------------------------------------------
# ⚡ Paralelismo da extração (FASE 2)
# ---------------------------------------------------------------------------
# PARSE_CONCURRENCY: abas abertas AO MESMO TEMPO por requisição. Mais paralelismo
# = mais rápido, porém mais RAM/CPU e mais risco de rate-limit. Padrão 4, máx 12.
# PARSE_CONCURRENCY=4

# MAX_CONCURRENCY: teto GLOBAL de abas do processo (todas as requisições somadas).
# Impede que várias requisições multipliquem as abas e estourem a memória.
# Deixe >= PARSE_CONCURRENCY. Padrão 8, máx 32.
# MAX_CONCURRENCY=8

# ---------------------------------------------------------------------------
# 🌐 Browser (Playwright / Chromium)
# ---------------------------------------------------------------------------
# HEADLESS=true            # false abre o navegador (debug visual)
# BLOCK_RESOURCES=true     # bloqueia imagens/fontes/mídia (mais rápido, menos banda)
# NAV_TIMEOUT_MS=30000     # timeout de navegação/busca
# DETAIL_TIMEOUT_MS=15000  # timeout ao esperar a página de detalhe

# ---------------------------------------------------------------------------
# 📨 Webhooks
# ---------------------------------------------------------------------------
# WEBHOOK_TIMEOUT_MS=15000  # timeout por POST de webhook
# WEBHOOK_RETRIES=2         # retentativas com backoff em caso de falha

# ---------------------------------------------------------------------------
# ✨ Enriquecimento (options.onlyInfosExtras) — visita o site do lead
# ---------------------------------------------------------------------------
# ENRICH_TIMEOUT_MS=5000    # timeout ao visitar o site do lead
# ENRICH_CONCURRENCY=4      # quantos sites visitar em paralelo (pool próprio)

# ---------------------------------------------------------------------------
# 🪄 Seletores do Google Maps (AUTOMÁTICOS)
# A extração usa atributos estáveis (aria-label, role, href, data-item-id) em vez
# de classes ofuscadas. Só sobrescreva se o Google mudar algo estrutural:
# LISTING=a[href^="https://www.google.com/maps/place/"]
# SCROLL=[role="feed"]
