{
  "name": "maps-to-leads",
  "version": "2.0.0",
  "description": "API open source de prospecção de leads a partir do Google Maps (TypeScript + Playwright). De maneira nenhuma apoiamos ou incentivamos a prática de SPAM, utilize com sabedoria.",
  "main": "dist/index.js",
  "workspaces": [
    "web"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "npm --workspace web run dev",
    "build": "npm run build:web && tsc",
    "build:web": "npm --workspace web run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "playwright install chromium"
  },
  "author": "Jonathan Henrique",
  "homepage": "https://apigratis.com.br",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-queue": "^0.0.13",
    "pino": "^9.5.0",
    "playwright": "^1.49.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/swagger-ui-express": "^4.1.6",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
